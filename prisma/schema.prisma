generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  USER
}

enum CharacterType {
  HISTORICAL
  FICTIONAL
  REAL_PERSON
  CUSTOM
}

enum CharacterVisibility {
  PUBLIC
  PRIVATE
}

enum CreationStatus {
  DRAFT
  DISTILLING
  FAILED
  READY
}

enum SourceKind {
  TEXT
  TXT
  MD
  DOCX
  PDF
  IMAGE
  PASTE
  OCR_PDF
}

enum ExtractionMethod {
  DIRECT_TEXT
  DOCX_EXTRACT
  PDF_TEXT
  OCR_VISION
  FALLBACK
}

enum ExtractionStatus {
  PENDING
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum CharacterMode {
  FULL
  PERSONA_ONLY
  MEMORY_ONLY
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

enum MemoryType {
  FACT
  PREFERENCE
  RELATIONSHIP
  EXPERIENCE
  TASK
}

model User {
  id              String            @id @default(cuid())
  username        String            @unique
  email           String?           @unique
  passwordHash    String
  role            UserRole          @default(USER)
  isActive        Boolean           @default(true)
  name            String?
  imageUrl        String?
  lastLoginAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accounts        Account[]
  sessions        Session[]
  characters      Character[]
  conversations   Conversation[]
  sourceFiles     SourceFile[]
  messages        Message[]
  corrections     Correction[]
  usageLogs       UsageLog[]
  quota           UserQuota?
  memories        Memory[]
  memorySummaries MemorySummary[]
  quotaChanges    QuotaChangeLog[]  @relation("QuotaActor")
  quotaTargets    QuotaChangeLog[]  @relation("QuotaTarget")
  adminActions    AdminActionLog[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AppConfig {
  key                      String   @id @default("default")
  defaultDistillationQuota Int      @default(3)
  defaultChatQuota         Int      @default(100)
  defaultTtsQuota          Int      @default(20)
  allowRegistration        Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model UserQuota {
  id                    String   @id @default(cuid())
  userId                String   @unique
  distillationLimit     Int      @default(3)
  distillationUsed      Int      @default(0)
  distillationRemaining Int      @default(3)
  chatLimit             Int      @default(100)
  chatUsed              Int      @default(0)
  chatRemaining         Int      @default(100)
  ttsLimit              Int      @default(20)
  ttsUsed               Int      @default(0)
  ttsRemaining          Int      @default(20)
  lastUsedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuotaChangeLog {
  id                        String   @id @default(cuid())
  actorId                   String
  targetUserId              String
  reason                    String?
  distillationLimitBefore   Int
  distillationLimitAfter    Int
  chatLimitBefore           Int
  chatLimitAfter            Int
  ttsLimitBefore            Int
  ttsLimitAfter             Int
  createdAt                 DateTime @default(now())
  actor                     User     @relation("QuotaActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser                User     @relation("QuotaTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([targetUserId, createdAt])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String?
  payload    Json?
  createdAt  DateTime @default(now())
  actor      User     @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([targetType, createdAt])
}

model Character {
  id               String               @id @default(cuid())
  userId           String?
  slug             String               @unique
  title            String
  description      String
  shortDescription String?
  type             CharacterType
  tags             String[]
  visibility       CharacterVisibility  @default(PRIVATE)
  disclaimer       String?
  coverImageUrl    String?
  creationStatus   CreationStatus       @default(DRAFT)
  creationStage    String?
  creationProgress Int                  @default(0)
  creationMessage  String?
  lastError        String?
  draftInput       Json?
  lastHeartbeatAt  DateTime?
  currentVersionId String?              @unique
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
  user             User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  currentVersion   CharacterVersion?    @relation("CurrentCharacterVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions         CharacterVersion[]   @relation("CharacterVersions")
  sourceFiles      SourceFile[]
  chunks           ExtractedChunk[]
  conversations    Conversation[]
  corrections      Correction[]
  voiceProfiles    VoiceProfile[]
  usageLogs        UsageLog[]
  distillationRuns DistillationResult[]
  memories         Memory[]
  memorySummaries  MemorySummary[]

  @@index([visibility, deletedAt, updatedAt])
  @@index([userId, deletedAt, updatedAt])
}

model CharacterVersion {
  id                  String               @id @default(cuid())
  characterId         String
  versionNumber       Int
  titleSnapshot       String
  descriptionSnapshot String
  personaPrompt       String
  memorySummary       String
  welcomeMessage      String
  sourceSummary       String
  characterProfile    Json
  voiceProfileJson    Json?
  modelUsed           String?
  tierUsed            String?
  confidence          Float?
  completeness        Float?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  character           Character            @relation("CharacterVersions", fields: [characterId], references: [id], onDelete: Cascade)
  currentFor          Character?           @relation("CurrentCharacterVersion")
  sourceFiles         SourceFile[]
  chunks              ExtractedChunk[]
  distillationRuns    DistillationResult[]
  voiceProfiles       VoiceProfile[]
  corrections         Correction[]

  @@unique([characterId, versionNumber])
  @@index([characterId, createdAt])
}

model SourceFile {
  id                 String            @id @default(cuid())
  userId             String?
  characterId        String?
  characterVersionId String?
  kind               SourceKind
  mimeType           String
  title              String?
  originalFilename   String?
  blobUrl            String?
  pageCount          Int?
  extractionMethod   ExtractionMethod?
  extractionStatus   ExtractionStatus  @default(PENDING)
  rawText            String?
  parsedText         String?
  normalizedText     String?
  parseError         String?
  sourceMeta         Json?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  character          Character?        @relation(fields: [characterId], references: [id], onDelete: SetNull)
  characterVersion   CharacterVersion? @relation(fields: [characterVersionId], references: [id], onDelete: SetNull)
  chunks             ExtractedChunk[]
}

model ExtractedChunk {
  id                 String           @id @default(cuid())
  characterId        String
  characterVersionId String
  sourceFileId       String
  chunkIndex         Int
  pageNumber         Int?
  paragraphIndex     Int?
  imageIndex         Int?
  content            String
  normalizedContent  String
  sourceLabel        String?
  embedding          Json?
  chunkMeta          Json?
  createdAt          DateTime         @default(now())
  character          Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterVersion   CharacterVersion @relation(fields: [characterVersionId], references: [id], onDelete: Cascade)
  sourceFile         SourceFile       @relation(fields: [sourceFileId], references: [id], onDelete: Cascade)

  @@index([characterVersionId, chunkIndex])
}

model DistillationResult {
  id                 String           @id @default(cuid())
  characterId        String
  characterVersionId String
  provider           String
  model              String?
  tier               String?
  structuredResult   Json
  sourceSummary      String
  latencyMs          Int?
  inputTokens        Int?
  outputTokens       Int?
  totalTokens        Int?
  createdAt          DateTime         @default(now())
  character          Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterVersion   CharacterVersion @relation(fields: [characterVersionId], references: [id], onDelete: Cascade)
}

model VoiceProfile {
  id                 String            @id @default(cuid())
  characterId        String
  characterVersionId String?
  name               String
  provider           String
  model              String?
  voiceId            String?
  preset             String?
  styleInstructions  String
  speed              Float             @default(1)
  stability          Float?
  similarity         Float?
  expressiveLevel    Float?
  language           String?
  speakingRegister   String?
  pauseStyle         String?
  emotionBaseline    String?
  energy             Float?
  pitchHint          String?
  styleExamples      Json?
  autoRead           Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  character          Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterVersion   CharacterVersion? @relation(fields: [characterVersionId], references: [id], onDelete: SetNull)
}

model Conversation {
  id          String        @id @default(cuid())
  characterId String
  userId      String
  title       String
  summary     String?
  isActive    Boolean       @default(true)
  lastMode    CharacterMode @default(FULL)
  lastModelId String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  corrections Correction[]
  usageLogs   UsageLog[]
  memories    Memory[]

  @@index([userId, characterId, isActive, updatedAt])
  @@index([characterId, updatedAt])
}

model Message {
  id             String         @id @default(cuid())
  conversationId String
  userId         String?
  role           MessageRole
  content        String
  plainText      String
  modelUsed      String?
  mode           CharacterMode?
  tier           String?
  latencyMs      Int?
  inputTokens    Int?
  outputTokens   Int?
  totalTokens    Int?
  metadata       Json?
  evidence       Json?
  audioUrl       String?
  audioProvider  String?
  audioCacheKey  String?
  createdAt      DateTime       @default(now())
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  corrections    Correction[]
  usageLogs      UsageLog[]

  @@index([conversationId, createdAt])
}

model Correction {
  id                 String            @id @default(cuid())
  characterId        String
  characterVersionId String?
  conversationId     String?
  messageId          String?
  userId             String?
  text               String
  normalizedText     String
  appliesToModes     CharacterMode[]
  createdAt          DateTime          @default(now())
  character          Character         @relation(fields: [characterId], references: [id], onDelete: Cascade)
  characterVersion   CharacterVersion? @relation(fields: [characterVersionId], references: [id], onDelete: SetNull)
  conversation       Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message            Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)
  user               User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Memory {
  id               String        @id @default(cuid())
  userId           String
  characterId      String
  conversationId   String?
  memoryType       MemoryType
  content          String
  salience         Float         @default(0.5)
  sourceMessageIds String[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  lastAccessedAt   DateTime?
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  character        Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  conversation     Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  embedding        MemoryEmbedding?

  @@index([userId, characterId, createdAt])
  @@index([userId, characterId, salience])
}

model MemorySummary {
  id                  String    @id @default(cuid())
  userId              String
  characterId         String
  relationshipSummary String
  userProfileSummary  String
  sharedSummary       String
  summaryText         String
  sourceMemoryCount   Int       @default(0)
  lastMessageAt       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
}

model MemoryEmbedding {
  id        String   @id @default(cuid())
  memoryId   String   @unique
  model      String?
  embedding  Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  memory     Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
}

model UsageLog {
  id             String        @id @default(cuid())
  userId         String?
  characterId    String?
  conversationId String?
  messageId      String?
  eventType      String
  provider       String?
  model          String?
  tier           String?
  latencyMs      Int?
  inputTokens    Int?
  outputTokens   Int?
  totalTokens    Int?
  success        Boolean       @default(true)
  errorCode      String?
  meta           Json?
  createdAt      DateTime      @default(now())
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  character      Character?    @relation(fields: [characterId], references: [id], onDelete: SetNull)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([createdAt, success])
}
